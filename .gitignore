# =============================================================================
# llm-wiki .gitignore
#
# Политика: коммитим только инфраструктуру (.claude/, bin/, _templates/,
# CLAUDE.md, ARCHITECTURE.md, README.md). Per-user контент и не-инфра
# dot-folders — не коммитим. Пустые .gitkeep оставляем как scaffolding,
# чтобы при `git clone` структура папок воссоздавалась.
#
# Подробнее — ARCHITECTURE.md §9.
# =============================================================================

# === Secrets ===
.env
.env.local

# === macOS / IDE / Editor ===
.DS_Store
*.swp
*.swo
*~
.vscode/
.idea/

# === Node (если появится тулинг) ===
node_modules/

# === Per-user content: raw/ ===
# Ignore everything inside raw/, but preserve .gitkeep scaffolding.
/raw/*
!/raw/.gitkeep
!/raw/meta/
/raw/meta/*
!/raw/meta/.gitkeep
!/raw/brainstorm/
/raw/brainstorm/*
!/raw/brainstorm/.gitkeep

# === Per-user content: wiki/ ===
/wiki/*
!/wiki/.gitkeep
!/wiki/ideas/
!/wiki/entities/
!/wiki/domains/
!/wiki/questions/
!/wiki/minds/
!/wiki/meta/
/wiki/ideas/*
!/wiki/ideas/.gitkeep
/wiki/entities/*
!/wiki/entities/.gitkeep
/wiki/domains/*
!/wiki/domains/.gitkeep
/wiki/questions/*
!/wiki/questions/.gitkeep
/wiki/minds/*
!/wiki/minds/.gitkeep
/wiki/meta/*
!/wiki/meta/.gitkeep

# === Per-user content: _attachments/ ===
/_attachments/

# === Dot-folders, кроме .claude ===
/.obsidian/
/.claudian/

# === ВКР draft ===
/PROJECT.md

# === Бинарные ассеты на корне (если случайно попадут) ===
*.png
*.jpg
*.webp
